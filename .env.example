# Copy this file to .env and fill in real values for local development.
# On Render, set these as Environment Variables in the dashboard instead
# of committing a .env file — see DEPLOYMENT.md.

# Local default uses SQLite so you can run the API with zero setup.
# For local Postgres testing, use something like:
# DATABASE_URL=postgresql://ledgr_user:yourpassword@localhost:5432/ledgr_db
DATABASE_URL=sqlite:///./ledgr_dev.db

# Generate a real secret with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=replace-this-with-a-long-random-string-before-deploying
